#!/usr/bin/env sh
# rimsky wrapper. Forwards every argument to the `rimsky` binary baked
# into the rimsky/all image, with the control-api endpoint
# pre-configured to the in-container address (http://localhost:8080
# from the rimsky container's perspective).
#
# Use from this directory:
#   ./rimsky health
#   ./rimsky template register example-template.yml
#
# For native-speed CLI on your laptop instead, install with:
#   go install github.com/fallguyconsulting/rimsky/cmd/rimsky@latest
# then `export RIMSKY_CONTROL_API=http://localhost:8080` (the host port
# the quickstart compose publishes) and call `rimsky` directly.

set -eu

DIR="$(cd "$(dirname "$0")" && pwd)"

# Pick whichever compose file is up. Default: docker-compose.yml.
COMPOSE_FILE="${RIMSKY_COMPOSE_FILE:-${DIR}/docker-compose.yml}"

# Run inside the container with the quickstart dir as the working directory
# (mounted at /quickstart by the compose file), so file arguments like
# `template register example-template.yml` resolve to the host files here.
exec docker compose -f "$COMPOSE_FILE" exec -T \
  --workdir /quickstart \
  -e RIMSKY_CONTROL_API=http://localhost:8080 \
  rimsky rimsky "$@"
